# .env.example – copy to .env and fill in your values.
#
# NEVER commit .env to version control.
# All values have safe defaults for local development.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the backend listens on inside the container.
PORT=8080

# Frontend port exposed to the host machine.
FRONTEND_PORT=80

# ── TLS (production / internet deployment) ────────────────────────────────────
# Set TLS_ENABLED=true and mount your certificate and key files.
# TLS_CERT_DIR should be the HOST directory containing your PEM files.
# The files must be named exactly as TLS_CERT_FILE / TLS_KEY_FILE inside the dir.
#
# Example with Let's Encrypt / Certbot:
#   TLS_ENABLED=true
#   TLS_CERT_DIR=/etc/letsencrypt/live/your-domain.com
#   TLS_CERT_FILE=/certs/fullchain.pem
#   TLS_KEY_FILE=/certs/privkey.pem
TLS_ENABLED=false
TLS_CERT_DIR=
TLS_CERT_FILE=
TLS_KEY_FILE=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# For production replace with your exact domain, e.g. https://timesync.example.com
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── Maconomy defaults (optional) ─────────────────────────────────────────────
# Pre-populate the Maconomy URL and company for all users.
# Users can still override these per-session in the UI.
MACONOMY_BASE_URL=
MACONOMY_COMPANY=
MACONOMY_API_BASEPATH=
MACONOMY_OAUTH_CLIENT_ID=
MACONOMY_OAUTH_REDIRECT_URI=
